{
  "name": "@openlove/bridge-telegram",
  "version": "0.1.0",
  "description": "Telegram bridge: text, voice messages, media",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openlove/core": "workspace:*",
    "@openlove/media": "workspace:*",
    "grammy": "^1.31.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}

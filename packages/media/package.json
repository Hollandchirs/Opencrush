{
  "name": "@openlove/media",
  "version": "0.1.0",
  "description": "Media generation: images (fal.ai), TTS (ElevenLabs/Edge), STT (Whisper)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fal-ai/client": "^1.2.0",
    "openai": "^4.73.0",
    "msedge-tts": "^1.3.4",
    "form-data": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}
